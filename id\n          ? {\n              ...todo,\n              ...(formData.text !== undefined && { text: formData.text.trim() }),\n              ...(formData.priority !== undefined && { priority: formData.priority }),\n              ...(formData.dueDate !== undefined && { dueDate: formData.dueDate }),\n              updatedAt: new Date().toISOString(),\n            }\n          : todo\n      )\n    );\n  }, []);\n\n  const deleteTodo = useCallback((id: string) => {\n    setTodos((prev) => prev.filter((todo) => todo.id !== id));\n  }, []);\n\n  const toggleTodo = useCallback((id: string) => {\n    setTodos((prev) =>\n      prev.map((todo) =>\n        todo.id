id\n          ? { ...todo, completed: !todo.completed, updatedAt: new Date().toISOString() }\n          : todo\n      )\n    );\n  }, []);\n\n  const clearCompleted = useCallback(() => {\n    setTodos((prev) => prev.filter((todo) => !todo.completed));\n  }, []);\n\n  const markAllCompleted = useCallback(() => {\n    const now = new Date().toISOString();\n    setTodos((prev) => prev.map((todo) => ({ ...todo, completed: true, updatedAt: now })));\n  }, []);\n\n  const markAllActive = useCallback(() => {\n    const now = new Date().toISOString();\n    setTodos((prev) => prev.map((todo) => ({ ...todo, completed: false, updatedAt: now })));\n  }, []);\n\n  const setFilterStatus = useCallback((status: FilterStatus) => {\n    setFilters((prev) => ({ ...prev, status }));\n  }, []);\n\n  const setSearch = useCallback((search: string) => {\n    setFilters((prev) => ({ ...prev, search }));\n  }, []);\n\n  const setFilterPriority = useCallback((priority: Priority | 'all') => {\n    setFilters((prev) => ({ ...prev, priority }));\n  }, []);\n\n  const setSortBy = useCallback((sortBy: TodoFilters['sortBy']) => {\n    setFilters((prev) => ({\n      ...prev,\n      sortBy,\n      sortOrder: prev.sortBy